# PostgreSQL (Neon). Usar la cadena "pooled" para la app y migraciones.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/divalus?sslmode=require"

# NextAuth v5 — generar con: npx auth secret  (mínimo 32 chars)
AUTH_SECRET="cambia-esto-por-un-secreto-de-32-chars-minimo"
AUTH_URL="http://localhost:3000"

# Nextpyme (fase 2). El token de emisión va POR EMPRESA en BD (Organizacion.nextpymeToken), no aquí.
NEXTPYME_BASE_URL="https://api.nextpyme.plus/api/ubl2.1"

# Cloudinary — almacenamiento de imágenes de productos.
# Cuenta única del SaaS; el aislamiento multi-empresa se hace por carpeta (productos/{organizacionId}).
# Solo servidor. NUNCA usar prefijo NEXT_PUBLIC_: el api_secret jamás debe llegar al cliente.
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
